// grange serve — the HTTP/JSON face (the seed of the hosted version).
//
// SINGLE-ACTOR BY CONSTRUCTION: the server is a sequential accept loop with
// zero goroutines — one request at a time touches the memtable, so there is
// nothing to race on and `machin check`'s inferred race analysis stays clean.
// (machweb's `serve` spawns a goroutine per connection; we deliberately call
// its machweb_handle directly instead.)
//
// Auth: every route except /health needs Authorization: Bearer <token>
// (or ?token=). Token comes from --token / GRANGE_TOKEN, else one is
// generated and printed at startup.

var g_srv_token = ""
var g_srv_db = ""
// parked long-poll watchers (single-actor: plain parallel slices, no locks)
var g_w_fd = []int{}
var g_w_tid = []string{}
var g_w_db = []string{}
var g_w_coll = []string{}
var g_w_since = []int{}
var g_w_deadline = []int{}
var g_park = 0
var g_srv_follow = 0
var g_shutdown = 0

func srv_json(status, body) (res) {
    res = response(status, "application/json", body)
}

func srv_err(status, etype, msg) (res) {
    res = srv_json(status, "{\"ok\":false,\"error\":{\"type\":\"" + etype + "\",\"message\":\"" + jesc(msg) + "\"}}")
}

func srv_ok(data) (res) {
    res = srv_json("200 OK", "{\"ok\":true,\"data\":" + data + "}")
}

// srv_role resolves the caller: ("admin","") | ("tenant",tid) | ("","").
func srv_role(req) (role, tid) {
    role = ""
    tid = ""
    tok := query(req, "token")
    h := header(req, "authorization")
    if has_prefix(h, "Bearer ") { tok = substr(h, 7, len(h)) }
    if len(tok) == 0 { return }
    if tok == g_srv_token { role = "admin"  return }
    if has(g_tenants, tok) == false && g_srv_follow == 1 {
        // a tenant created on the primary after this follower started:
        // refresh _sys from disk and rescan before rejecting
        uok, uerr := gr_use(g_srv_db, "_sys")
        if uok == 1 { gr_refresh() }
        tn_load_cache()
    }
    if has(g_tenants, tok) {
        role = "tenant"
        tid = g_tenants[tok]
    }
}

// srv_body_field pulls a raw JSON token out of the request body ("" if absent).
func srv_body_field(req, f) (tok) {
    tok = ""
    v, err := json_get(req.body, "." + f)
    if len(err) == 0 { tok = v }
}

// srv_body_str is srv_body_field with the quotes of a JSON string stripped.
func srv_body_str(req, f) (s) {
    s = srv_body_field(req, f)
    if len(s) > 1 && charat(s, 0) == "\"" { s = substr(s, 1, len(s) - 1) }
}

// srv_coll resolves the request's collection (?coll= or body "coll"),
// defaulting to "default", and switches the engine to it under `root`.
func srv_use(req, root) (ok) {
    c := query(req, "coll")
    if len(c) == 0 { c = srv_body_str(req, "coll") }
    if len(c) == 0 { c = "default" }
    ok = 0
    if valid_id(c) == 0 { return }
    if c == "_sys" { return }
    uok, uerr := gr_use(root, c)
    ok = uok
}

// watch_payload renders changes after `since` for the CURRENT collection.
func watch_payload(since) (data) {
    items := []string{}
    resync := 0
    if since > g_seq { resync = 1 }
    floor := g_seq - len(g_chg)
    if floor < g_seq_base { floor = g_seq_base }
    if since < floor { resync = 1 }
    if resync == 0 {
        i := 0
        while i < len(g_chg) {
            sv, serr := json_get(g_chg[i], ".seq")
            if len(serr) == 0 && parse_int(sv) > since { items = append(items, g_chg[i]) }
            i = i + 1
        }
    }
    data = "{\"seq\":" + str(g_seq) + ",\"resync\":" + str(resync) + ",\"changes\":[" + join(items, ",") + "]}"
}

// srv_write_res writes a Response to fd and closes it (our own loop's writer).
func srv_write_res(fd, res) {
    out := "HTTP/1.1 " + res.status + "\r\nContent-Type: " + res.ctype + "\r\nContent-Length: " + str(len(res.body)) + "\r\nAccess-Control-Allow-Origin: *\r\nConnection: close\r\n\r\n" + res.body
    write(fd, out)
    close(fd)
}

// watch_park stashes the current connection until news or deadline.
var g_park_tid = ""

func watch_park(fd, since, timeout_s) {
    g_w_fd = append(g_w_fd, fd)
    g_w_tid = append(g_w_tid, g_park_tid)
    g_w_db = append(g_w_db, g_db)
    g_w_coll = append(g_w_coll, g_coll)
    g_w_since = append(g_w_since, since)
    g_w_deadline = append(g_w_deadline, now_ms() + timeout_s * 1000)
}

// watch_tick wakes parked watchers whose collection advanced or deadline hit.
func watch_tick() {
    if len(g_w_fd) == 0 { return }
    nowms := now_ms()
    kfd := []int{}
    ktid := []string{}
    kdb := []string{}
    kcoll := []string{}
    ksince := []int{}
    kdl := []int{}
    i := 0
    while i < len(g_w_fd) {
        uok, uerr := gr_use(g_w_db[i], g_w_coll[i])
        if g_srv_follow == 1 && uok == 1 { gr_refresh() }
        fire := 0
        if uok == 0 { fire = 1 }
        if g_seq > g_w_since[i] { fire = 1 }
        if nowms >= g_w_deadline[i] { fire = 1 }
        if fire == 1 {
            srv_write_res(g_w_fd[i], srv_ok(watch_payload(g_w_since[i])))
        } else {
            kfd = append(kfd, g_w_fd[i])
            ktid = append(ktid, g_w_tid[i])
            kdb = append(kdb, g_w_db[i])
            kcoll = append(kcoll, g_w_coll[i])
            ksince = append(ksince, g_w_since[i])
            kdl = append(kdl, g_w_deadline[i])
        }
        i = i + 1
    }
    g_w_fd = kfd
    g_w_tid = ktid
    g_w_db = kdb
    g_w_coll = kcoll
    g_w_since = ksince
    g_w_deadline = kdl
}

func srv_handle(req) (res) {
    if req.method == "GET" && (req.path == "/" || req.path == "/index.html") {
        res = ok_html(landing_html())
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/llms.txt") {
        res = ok_text(llms_txt())
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/guide") {
        res = ok_text(llms_txt())
        return
    }
    if req.path == "/health" || has_prefix(req.path, "/health?") {
        res = srv_ok("{\"status\":\"up\"}")
        return
    }
    // self-serve tenant signup: a peage wallet is the only credential
    if req.method == "POST" && req.path == "/tenants" {
        w := header(req, "x-peage-wallet")
        if has_prefix(w, "pw_") == false {
            res = srv_err("400 Bad Request", "input", "send X-Peage-Wallet: pw_... (mint one: POST " + tn_peage_url() + "/v1/wallets — see /llms.txt of peage)")
            return
        }
        tid, ttok := tn_create(w, srv_body_str(req, "name"))
        res = srv_ok("{\"tenant\":\"" + tid + "\",\"token\":\"" + ttok + "\",\"pricing\":{\"storage_cents_per_gb_month\":" + str(tn_price()) + ",\"free_bytes\":" + str(tn_free_bytes()) + ",\"pay_rail\":\"peage\"},\"how\":\"use Authorization: Bearer " + ttok + " on /put /get /find /count /agg /index /stats /usage — your data is isolated and metered by disk bytes\"}")
        return
    }
    role, tid := srv_role(req)
    if len(role) == 0 {
        res = srv_err("401 Unauthorized", "auth", "missing or wrong bearer token (tenants self-serve at POST /tenants with X-Peage-Wallet)")
        return
    }
    if role == "tenant" {
        if tn_rl_check(tid) == 1 {
            res = srv_err("429 Too Many Requests", "rate-limited", "fair-use cap: " + str(tn_rate_limit()) + " requests/min per tenant; retry_after_seconds=" + str(tn_rl_retry_after(tid)) + " (throttling is recorded and visible in GET /usage)")
            return
        }
    }
    if g_srv_follow == 0 { tn_sweep() }
    // tenants get a two-level namespace: db (?db=, default "default") / collection
    root := g_srv_db
    if role == "tenant" {
        dbname := query(req, "db")
        if len(dbname) == 0 { dbname = srv_body_str(req, "db") }
        if len(dbname) == 0 { dbname = "default" }
        if valid_id(dbname) == 0 || contains(dbname, ".") {
            res = srv_err("400 Bad Request", "input", "bad db name")
            return
        }
        root = tn_root(tid) + "/" + dbname
    }
    if role == "tenant" && req.method == "GET" && has_prefix(req.path, "/dbs") {
        entries := list_dir(tn_root(tid))
        items := []string{}
        i := 0
        while i < len(entries) {
            if contains(entries[i], ".") == false {
                items = append(items, "\"" + jesc(entries[i]) + "\"")
            }
            i = i + 1
        }
        res = srv_ok("{\"dbs\":[" + join(items, ",") + "]}")
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/usage") {
        utid := tid
        if role == "admin" { utid = query(req, "tenant") }
        if len(utid) == 0 {
            res = srv_err("400 Bad Request", "input", "admin usage needs ?tenant=<tid>")
            return
        }
        res = srv_ok(tn_usage(utid))
        return
    }
    if role == "admin" && req.method == "GET" && has_prefix(req.path, "/tenants") {
        ok2, errmsg2 := gr_use(g_srv_db, "_sys")
        res = srv_ok(q_find("", 1000))
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/collections") {
        entries := list_dir(root)
        items := []string{}
        i := 0
        while i < len(entries) {
            if contains(entries[i], ".") == false {
                items = append(items, "\"" + jesc(entries[i]) + "\"")
            }
            i = i + 1
        }
        res = srv_ok("{\"collections\":[" + join(items, ",") + "]}")
        return
    }
    if g_srv_follow == 1 && req.method == "POST" && req.path != "/shutdown" {
        res = srv_err("403 Forbidden", "read-only", "this is a follower; write to the primary")
        return
    }
    if req.method == "POST" && req.path == "/shutdown" && role != "admin" {
        res = srv_err("403 Forbidden", "auth", "admin only")
        return
    }
    if srv_use(req, root) == 0 {
        res = srv_err("400 Bad Request", "input", "bad collection name or open failed")
        return
    }
    if g_srv_follow == 1 { gr_refresh() }
    if req.method == "POST" && req.path == "/put" {
        doc := srv_body_field(req, "doc")
        if valid_doc(doc) == 0 {
            res = srv_err("400 Bad Request", "input", "body must be {\"doc\":{...}} with minified JSON")
            return
        }
        id := srv_body_str(req, "id")
        if len(id) == 0 { id = to_hex(rand_bytes(8)) }
        if valid_id(id) == 0 {
            res = srv_err("400 Bad Request", "input", "invalid id")
            return
        }
        ttl := parse_int(srv_body_field(req, "ttl_seconds"))
        if ttl > 0 {
            if charat(doc, 0) != "{" {
                res = srv_err("400 Bad Request", "input", "ttl_seconds needs an object doc")
                return
            }
            doc = "{\"_expires\":" + str(now_ms() + ttl * 1000) + "," + substr(doc, 1, len(doc))
        }
        gr_put(id, doc)
        if gr_commit() == 0 {
            res = srv_err("500 Internal Server Error", "internal", "wal chunk write failed")
            return
        }
        res = srv_ok("{\"id\":\"" + jesc(id) + "\"}")
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/get") {
        id := query(req, "id")
        doc, found := gr_get(id)
        if found == 0 {
            res = srv_err("404 Not Found", "not-found", "no document with id " + id)
            return
        }
        res = srv_ok("{\"id\":\"" + jesc(id) + "\",\"doc\":" + doc + "}")
        return
    }
    if req.method == "POST" && req.path == "/del" {
        id := srv_body_str(req, "id")
        if gr_del(id) == 0 {
            res = srv_err("404 Not Found", "not-found", "no document with id " + id)
            return
        }
        if gr_commit() == 0 {
            res = srv_err("500 Internal Server Error", "internal", "wal chunk write failed")
            return
        }
        res = srv_ok("{\"id\":\"" + jesc(id) + "\",\"deleted\":true}")
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/find") {
        limit := parse_int(query(req, "limit"))
        if limit == 0 { limit = 100 }
        res = srv_ok(q_find(query(req, "where"), limit))
        return
    }
    // bulk: newline-delimited ops, ONE commit for the whole batch.
    //   {...}            put, auto id
    //   <id>\t{...}      put with id
    //   -\t<id>          delete
    if req.method == "POST" && (req.path == "/bulk" || has_prefix(req.path, "/bulk?")) {
        lines := split(req.body, "\n")
        if len(lines) > 50000 {
            res = srv_err("400 Bad Request", "input", "max 50000 ops per bulk request")
            return
        }
        // pass 1: validate everything — nothing stages until the batch is clean,
        // so a bad line can never leak a partial batch into the next commit
        i := 0
        while i < len(lines) {
            ln := trim(lines[i])
            if len(ln) > 0 && has_prefix(ln, "-\t") == false {
                tabp := index(ln, "\t")
                bdoc := ln
                bid := "x"
                if tabp > 0 {
                    bid = substr(ln, 0, tabp)
                    bdoc = substr(ln, tabp + 1, len(ln))
                }
                if valid_id(bid) == 0 || valid_doc(bdoc) == 0 {
                    res = srv_err("400 Bad Request", "input", "bad op at line " + str(i + 1) + " (nothing applied)")
                    return
                }
            }
            i = i + 1
        }
        // pass 2: stage + single commit
        ids := []string{}
        nops := 0
        i = 0
        while i < len(lines) {
            ln := trim(lines[i])
            if len(ln) > 0 {
                if has_prefix(ln, "-\t") {
                    gr_del(substr(ln, 2, len(ln)))
                    nops = nops + 1
                } else {
                    tabp := index(ln, "\t")
                    bid := ""
                    bdoc := ln
                    if tabp > 0 {
                        bid = substr(ln, 0, tabp)
                        bdoc = substr(ln, tabp + 1, len(ln))
                    }
                    if len(bid) == 0 { bid = to_hex(rand_bytes(8)) }
                    gr_put(bid, bdoc)
                    if len(ids) < 100 { ids = append(ids, "\"" + jesc(bid) + "\"") }
                    nops = nops + 1
                }
            }
            i = i + 1
        }
        if gr_commit() == 0 {
            res = srv_err("500 Internal Server Error", "internal", "wal chunk write failed")
            return
        }
        res = srv_ok("{\"ops\":" + str(nops) + ",\"ids\":[" + join(ids, ",") + "]}")
        return
    }
    // long-poll: block (parked socket) until this collection changes past ?since=
    if req.method == "GET" && has_prefix(req.path, "/watch") {
        since := parse_int(query(req, "since"))
        tmo := parse_int(query(req, "timeout"))
        if tmo < 1 { tmo = 25 }
        if tmo > 55 { tmo = 55 }
        if g_seq > since || since > g_seq {
            res = srv_ok(watch_payload(since))
            return
        }
        if len(g_w_fd) >= 100 {
            res = srv_err("503 Service Unavailable", "capacity", "too many parked watchers")
            return
        }
        mine := 0
        wi := 0
        while wi < len(g_w_tid) {
            if g_w_tid[wi] == tid { mine = mine + 1 }
            wi = wi + 1
        }
        if role == "tenant" && mine >= 5 {
            res = srv_err("429 Too Many Requests", "watch-capacity", "fair-use cap: max 5 concurrent watchers per tenant")
            return
        }
        g_park_tid = tid
        g_park = tmo
        res = srv_ok("")
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/export") {
        if query(req, "format") == "lines" {
            gr_sweep_expired()
            ids := keys(g_mem)
            lines := []string{}
            i := 0
            while i < len(ids) {
                lines = append(lines, ids[i] + "\t" + g_mem[ids[i]])
                i = i + 1
            }
            res = response("200 OK", "text/plain", join(lines, "\n"))
            return
        }
        res = srv_ok(q_find(query(req, "where"), 0))
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/count") {
        res = srv_ok(q_count(query(req, "where")))
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/agg") {
        f := query(req, "group-by")
        if len(f) == 0 {
            res = srv_err("400 Bad Request", "input", "missing group-by query param")
            return
        }
        res = srv_ok(q_agg_full(f, query(req, "sum"), query(req, "minmax")))
        return
    }
    if req.method == "POST" && req.path == "/index" {
        f := srv_body_str(req, "field")
        if len(f) == 0 {
            res = srv_err("400 Bad Request", "input", "body must be {\"field\":\"...\",\"sums\":\"a,b\"}")
            return
        }
        if gr_index_add(f, srv_body_str(req, "sums"), srv_body_str(req, "kind")) == 0 {
            res = srv_err("500 Internal Server Error", "internal", "could not persist index declaration")
            return
        }
        res = srv_ok("{\"field\":\"" + jesc(f) + "\",\"docs_indexed\":" + str(gr_count()) + "}")
        return
    }
    if req.method == "POST" && req.path == "/compact" {
        if gr_compact() == 0 {
            res = srv_err("500 Internal Server Error", "internal", "compaction failed; old files were NOT deleted")
            return
        }
        res = srv_ok("{\"gen\":" + str(g_gen) + ",\"docs\":" + str(gr_count()) + "}")
        return
    }
    if req.method == "GET" && has_prefix(req.path, "/stats") {
        res = srv_ok("{\"coll\":\"" + jesc(g_coll) + "\",\"docs\":" + str(gr_count()) + ",\"gen\":" + str(g_gen) + ",\"chunks_replayed\":" + str(g_replayed_chunks) + ",\"indexes\":" + str(len(g_ifields)) + "}")
        return
    }
    if req.method == "POST" && req.path == "/shutdown" {
        uok2, uerr2 := gr_use(g_srv_db, "_sys")
        if uok2 == 1 { tn_rl_flush()  gr_commit() }
        gr_commit()
        g_shutdown = 1
        res = srv_ok("{\"stopping\":true}")
        return
    }
    res = srv_err("404 Not Found", "not-found", "no such route; see grange guide")
}

func cmd_serve(fs) {
    do_open(fs)
    g_srv_db = need_db(fs)
    if flag_on(fs, "follow") { g_srv_follow = 1 }
    gr_park()
    tn_load_cache()
    g_sweep_last = now_ms()
    port := flag_int_val(fs, "port")
    if port == 0 { port = 4444 }
    g_srv_token = flag_get(fs, "token")
    if len(g_srv_token) == 0 { g_srv_token = env("GRANGE_TOKEN") }
    if len(g_srv_token) == 0 { g_srv_token = to_hex(rand_bytes(16)) }
    harden(16777216, 30000)
    println("{\"event\":\"listening\",\"port\":" + str(port) + ",\"db\":\"" + jesc(flag_get(fs, "db")) + "\",\"coll\":\"" + jesc(flag_get(fs, "coll")) + "\",\"docs\":" + str(gr_count()) + ",\"token\":\"" + g_srv_token + "\"}")
    flush()
    server := listen(port)
    socket_timeout(server, 250)
    for {
        conn := accept(server)
        if conn >= 0 {
            started := now_ms()
            socket_timeout(conn, 5000)
            raw := read_request(conn)
            if len(raw) == 0 {
                close(conn)
            } else {
                req := parse_request(raw)
                req.remote = peer_addr(conn)
                g_park = 0
                res := srv_handle(req)
                if g_park > 0 {
                    since := parse_int(query(req, "since"))
                    watch_park(conn, since, g_park)
                } else {
                    srv_write_res(conn, res)
                    access_log(req, res.status, len(res.body), now_ms() - started)
                    if g_shutdown == 1 {
                        write(2, "{\"event\":\"shutdown\"}\n")
                        exit(0)
                    }
                }
            }
        }
        watch_tick()
    }
}
