// grange engine tests — run: machin test src/engine.src tests/engine_test.src

func tdir() (d) {
    d = "/tmp/grange-test-" + str(now_ms())
}

func main() {
    db := tdir()

    // put/get/commit
    ok, errmsg := gr_open(db, "t")
    assert(ok == 1, "open fresh db")
    gr_put("a", "{\"x\":1}")
    gr_put("b", "{\"x\":2}")
    assert(gr_commit() == 1, "commit chunk")
    doc, found := gr_get("a")
    assert_eq_int(found, 1, "get a found")
    assert_eq_str(doc, "{\"x\":1}", "get a doc")
    assert_eq_int(gr_count(), 2, "count 2")

    // durability: reopen replays the chunk
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 2, "reopen count 2")
    assert_eq_int(g_replayed_chunks, 1, "one chunk replayed")

    // overwrite latest-wins + delete
    gr_put("a", "{\"x\":9}")
    gr_del("b")
    gr_commit()
    ok, errmsg = gr_open(db, "t")
    doc, found = gr_get("a")
    assert_eq_str(doc, "{\"x\":9}", "overwrite wins after replay")
    doc, found = gr_get("b")
    assert_eq_int(found, 0, "tombstone applied after replay")
    assert_eq_int(gr_count(), 1, "count 1 after del")

    // compact folds chunks into a segment, state survives
    assert(gr_compact() == 1, "compact")
    assert_eq_int(g_gen, 1, "gen bumped")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 1, "count 1 after compact+reopen")
    assert_eq_int(g_replayed_chunks, 0, "no chunks after compact")
    doc, found = gr_get("a")
    assert_eq_str(doc, "{\"x\":9}", "doc survives compaction")

    // corrupt (torn) chunk is skipped, committed prefix survives
    gr_put("c", "{\"x\":3}")
    gr_commit()
    write_file(db + "/t/wal-" + gr_pad6(g_gen) + "-" + gr_pad6(g_next_chunk) + ".grg", "p|zz\n{\"x\":99}\n#|1|badbadbadbad\n")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(g_skipped_chunks, 1, "torn chunk skipped")
    assert_eq_int(gr_count(), 2, "committed prefix intact")
    doc, found = gr_get("zz")
    assert_eq_int(found, 0, "torn write not applied")
    // writes continue past the skipped chunk number
    gr_put("d", "{\"x\":4}")
    assert(gr_commit() == 1, "commit after torn chunk")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 3, "write-after-corruption durable")

    // fresh collection in same db is isolated
    ok, errmsg = gr_open(db, "other")
    assert_eq_int(gr_count(), 0, "collections isolated")

    // ---- M1: indexes + registers ----
    ok, errmsg = gr_open(db, "ix")
    gr_put("a", "{\"s\":\"x\",\"v\":5}")
    gr_put("b", "{\"s\":\"x\",\"v\":7}")
    gr_put("c", "{\"s\":\"y\",\"v\":1}")
    gr_commit()
    gr_index_add("s", "v")
    assert_eq_int(g_bcount["s\t\"x\""], 2, "bucket count x=2")
    assert_eq_int(len(g_buckets["s\t\"x\""]), 2, "bucket ids x=2")
    assert_eq_str(ix_fstr(g_breg["s\t\"x\"\tv"]), "12", "register sum x=12")
    // update moves buckets and registers
    gr_put("a", "{\"s\":\"y\",\"v\":10}")
    assert_eq_int(g_bcount["s\t\"x\""], 1, "update: x count drops")
    assert_eq_int(g_bcount["s\t\"y\""], 2, "update: y count grows")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "11", "update: y sum 11")
    // delete maintains registers
    gr_del("c")
    gr_commit()
    assert_eq_int(g_bcount["s\t\"y\""], 1, "del: y count drops")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "10", "del: y sum 10")
    // declarations persist; rebuild after reopen matches
    ok, errmsg = gr_open(db, "ix")
    assert_eq_int(len(g_ifields), 1, "index decl persisted")
    assert_eq_int(g_bcount["s\t\"x\""], 1, "rebuilt count x")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "10", "rebuilt register y")
    // numeric tokens index too
    gr_put("n1", "{\"k\":42,\"v\":1}")
    gr_commit()
    gr_index_add("k", "")
    assert_eq_int(g_bcount["k\t42"], 1, "numeric token bucket")
    assert_eq_str(ix_bucket("k", "42"), "k\t42", "ix_bucket resolves raw token")

    // ---- M2: where-ops (range filters) + query layer ----
    ok, errmsg = gr_open(db, "rq")
    gr_put("r1", "{\"s\":\"a\",\"v\":5}")
    gr_put("r2", "{\"s\":\"a\",\"v\":50}")
    gr_put("r3", "{\"s\":\"b\",\"v\":500}")
    gr_commit()
    f2, o2, v2 := wh_pairs("v>=50")
    assert_eq_int(len(f2), 1, "wh_pairs one clause")
    assert_eq_str(o2[0], ">=", "wh_pairs op >=")
    assert_eq_int(wh_match("{\"v\":50}", f2, o2, v2), 1, "v>=50 matches 50")
    assert_eq_int(wh_match("{\"v\":49}", f2, o2, v2), 0, "v>=50 rejects 49")
    f3, o3, v3 := wh_pairs("s=a,v<50")
    assert_eq_int(len(f3), 2, "wh_pairs two clauses")
    assert_eq_int(wh_match("{\"s\":\"a\",\"v\":5}", f3, o3, v3), 1, "combined eq+range matches")
    assert_eq_int(wh_match("{\"s\":\"a\",\"v\":50}", f3, o3, v3), 0, "combined rejects on range")
    cjson := q_count("v>5")
    cval, cerr := json_get(cjson, ".count")
    assert_eq_str(cval, "2", "q_count v>5 = 2")
    fjson := q_find("s=a,v>=50", 0)
    fval, ferr := json_get(fjson, ".count")
    assert_eq_str(fval, "1", "q_find combined = 1")
    ajson := q_agg("s", "v")
    asum, aerr := json_get(ajson, ".groups[1].sum_v")
    acnt, aerr2 := json_get(ajson, ".groups[1].count")
    assert(len(aerr) == 0, "q_agg has groups")

    // ix_fstr precision (the %g bug): big integral sums print exactly
    assert_eq_str(ix_fstr(16649667.0), "16649667", "fstr big int exact")
    assert_eq_str(ix_fstr(499.5), "499.5", "fstr fraction")
    assert_eq_str(ix_fstr(0.0 - 2.25), "-2.25", "fstr negative")

    test_summary()
}
