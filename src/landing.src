// grange landing + llms.txt — the open (unauthed) face of the hosted instance.
// The interface is the docs: /llms.txt is the full contract written for agents,
// / is a one-page human summary in the intrane.fr house style.

func llms_txt() (t) {
    t = "# grange — a document database your agent can pay for\n\n" +
        "grange is an agent-first document DB: one static binary (MFL/machin), crash-safe\n" +
        "WAL, secondary indexes with O(1) count/sum/avg registers, sorted range indexes.\n" +
        "Faster than SQLite on every indexed workload at 100k docs (see the README bench).\n" +
        "OSS: https://github.com/javimosch/grange  ·  This hosted instance: https://grange.intrane.fr\n" +
        "READ REPLICA: https://read.grange.intrane.fr — same tokens, GET routes only (find/count/agg/get/watch/export); point read-heavy agents here, writes go to the primary\n\n" +
        "## Get a namespace (self-serve; a peage wallet is the only credential)\n\n" +
        "1. mint a wallet:  curl -s -X POST https://peage.intrane.fr/v1/wallets -d '{}'    (save the pw_ token; docs: https://peage.intrane.fr/llms.txt)\n" +
        "2. fund it:        curl -s -X POST https://peage.intrane.fr/v1/topup -H 'Authorization: Bearer pw_...' -d '{\"amount_cents\":500}'   -> a Stripe URL your human pays once\n" +
        "3. sign up here:   curl -s -X POST https://grange.intrane.fr/tenants -H 'X-Peage-Wallet: pw_...' -d '{\"name\":\"my agent\"}'\n" +
        "                   -> {\"tenant\":\"t...\",\"token\":\"gt_...\"}   (save the gt_ token — it is your database)\n\n" +
        "## Pricing (pay-as-you-go, no subscription)\n\n" +
        "Storage: " + str(tn_price()) + " cents/GB/month, first " + str(tn_free_bytes() / 1048576) + " MB free. Accrued continuously\n" +
        "(price/30 per GB-day), charged to your wallet via peage when >= 5 cents. Queries and\n" +
        "writes are free. GET /usage shows bytes, accrual, and charges at any time.\n\n" +
        "## The API (Authorization: Bearer gt_... on every call; ?coll= picks a collection, default 'default')\n\n" +
        "PUT     curl -s -X POST $G/put -H \"$A\" -d '{\"coll\":\"leads\",\"id\":\"l1\",\"doc\":{\"co\":\"acme\",\"score\":9}}'   # id optional (auto)\n" +
        "GET     curl -s \"$G/get?coll=leads&id=l1\" -H \"$A\"\n" +
        "DEL     curl -s -X POST $G/del -H \"$A\" -d '{\"coll\":\"leads\",\"id\":\"l1\"}'\n" +
        "FIND    curl -s \"$G/find?coll=leads&where=score%3E%3D5&limit=50\" -H \"$A\"      # where: f=v,f2>v2 (AND; = > < >= <=)\n" +
        "COUNT   curl -s \"$G/count?coll=leads&where=co%3Dacme\" -H \"$A\"                 # O(1) if the field is indexed\n" +
        "INDEX   curl -s -X POST $G/index -H \"$A\" -d '{\"coll\":\"leads\",\"field\":\"co\",\"sums\":\"score\"}'   # kind:\"range\" for > < >= <=\n" +
        "AGG     curl -s \"$G/agg?coll=leads&group-by=co&sum=score\" -H \"$A\"             # count/sum/avg O(1) via registers; minmax= scans\n" +
        "BULK    curl -s -X POST \"$G/bulk?coll=leads\" -H \"$A\" --data-binary @ops.ndjson   # one line per op: '{...}' put auto-id · 'id<TAB>{...}' put · '-<TAB>id' del; ONE commit, all-or-nothing; 263k docs/s measured\n" +
        "COLLS   curl -s $G/collections -H \"$A\"\n" +
        "DBS     curl -s $G/dbs -H \"$A\"                                              # tenants have MULTIPLE databases: pass db= on any call (default 'default')\n" +
        "STATS   curl -s \"$G/stats?coll=leads\" -H \"$A\"\n" +
        "COMPACT curl -s -X POST $G/compact -H \"$A\" -d '{\"coll\":\"leads\"}'             # fold WAL chunks; run when stats.chunks_replayed grows\n" +
        "WATCH   curl -s \"$G/watch?coll=jobs&since=0&timeout=25\" -H \"$A\"       # LONG-POLL: blocks until the collection changes past since -> {seq,changes:[{seq,op,id}]}; poll again with the returned seq\n" +
        "EXPORT  curl -s \"$G/export?coll=leads&format=lines\" -H \"$A\"              # NDJSON 'id<TAB>doc' lines — pipe straight into /bulk of another grange\n" +
        "USAGE   curl -s $G/usage -H \"$A\"\n" +
        "HEALTH  curl -s $G/health                                                      # open, no auth\n\n" +
        "Docs are single-line minified JSON. Errors: {\"ok\":false,\"error\":{type,message}} with proper HTTP codes.\n\n" +
        "## Client SDKs (same surface everywhere: db(...).coll(...) scoping + put/get/find/count/agg/index/put_many)\n\n" +
        "Python  pip install grange-db\n" +
        "        from grange_db import Grange\n" +
        "        leads = Grange(url, token).db('crm').coll('leads')\n" +
        "        leads.put({'co':'acme'}); leads.count('co=acme'); leads.put_many([{...},...])\n\n" +
        "Node    npm install grange-db     (>=18, zero deps)\n" +
        "        const { Grange } = require('grange-db')\n" +
        "        const leads = new Grange({url, token}).db('crm').coll('leads')\n" +
        "        await leads.put({co:'acme'}); await leads.count('co=acme'); await leads.putMany([...])\n\n" +
        "Go      go get github.com/javimosch/grange/sdk/go\n" +
        "        leads := grange.New(url, token).DB(\"crm\").Coll(\"leads\")\n" +
        "        id, _ := leads.Put(\"\", map[string]any{\"co\":\"acme\"}); n, _ := leads.Count(\"co=acme\")\n\n" +
        "machin  compose sdk/machin/grange_client.src (https://github.com/javimosch/grange)\n" +
        "        g := grange_client(url, token)  g = grange_use(g, \"crm\", \"leads\")\n" +
        "        id, ok := grange_put(g, \"\", doc)  n := grange_count(g, \"co=acme\")\n\n" +
        "Durability: every write request is one immutable checksummed WAL chunk (process-crash-exact).\n" +
        "Your data is exportable at any time and REPLICABLE: `grange follow --from https://grange.intrane.fr --rtoken gt_... --db ./local` pulls a live local replica over the /watch feed (resync via export, then deltas). The engine is OSS — self-host the same binary if you outgrow the hosted rail.\n"
}

func landing_html() (h) {
    h = "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">" +
        "<title>grange — a document database your agent can pay for</title>" +
        "<meta name=\"description\" content=\"Agent-first document DB: one static binary, crash-safe, faster than SQLite on indexed workloads. Hosted pay-as-you-go at 0.15EUR/GB/month via peage.\">" +
        "<style>:root{--bg:#0a0a0c;--panel:#101014;--line:#1f1f26;--fg:#e2e8f0;--dim:#8b93a3;--acc:#4ade80}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--fg);font-family:ui-monospace,SFMono-Regular,Menlo,monospace;line-height:1.55}main{max-width:820px;margin:0 auto;padding:3rem 1.25rem}h1{font-size:2rem;margin:.2rem 0}h1 em{color:var(--acc);font-style:normal}h2{color:var(--acc);font-size:1.05rem;margin-top:2.4rem}p{color:var(--dim)}strong{color:var(--fg)}pre{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:14px;overflow-x:auto;font-size:13px}.tag{display:inline-block;border:1px solid var(--line);border-radius:99px;padding:2px 10px;font-size:12px;color:var(--dim);margin-right:6px}a{color:var(--acc)}footer{margin-top:3rem;color:var(--dim);font-size:12.5px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}@media(max-width:640px){.grid{grid-template-columns:1fr}}.card{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:1rem}.card h3{margin:0 0 .4rem;color:var(--fg);font-size:.95rem}.card p{font-size:13px;margin:.3rem 0}table{border-collapse:collapse;font-size:13px;width:100%}td,th{border:1px solid var(--line);padding:6px 10px;text-align:left}th{color:var(--fg)}td{color:var(--dim)}</style></head><body><main>" +
        "<div><span class=\"tag\">agent-first</span><span class=\"tag\">crash-safe</span><span class=\"tag\">one static binary</span><span class=\"tag\">pay-as-you-go</span></div>" +
        "<h1><em>grange</em> — a document database your agent can pay for</h1>" +
        "<p><strong>Agents don't want a database console — they want JSON in, JSON out, and a bill they can settle themselves.</strong> grange is a document DB written in <a href=\"https://github.com/javimosch/machin\">machin</a>: crash-safe WAL, indexes with O(1) aggregates, range queries. Embed it, run it, or use this hosted instance — signup is one curl with a <a href=\"https://peage.intrane.fr\">peage</a> wallet.</p>" +
        "<pre># get an isolated, metered namespace (the wallet IS the signup)\ncurl -s -X POST https://grange.intrane.fr/tenants -H 'X-Peage-Wallet: pw_...' -d '{\"name\":\"my agent\"}'\n# -&gt; {\"tenant\":\"t...\",\"token\":\"gt_...\"}\n\ncurl -s -X POST https://grange.intrane.fr/put -H 'Authorization: Bearer gt_...' \\\n  -d '{\"coll\":\"leads\",\"doc\":{\"co\":\"acme\",\"score\":9}}'\ncurl -s 'https://grange.intrane.fr/agg?coll=leads&amp;group-by=co&amp;sum=score' -H 'Authorization: Bearer gt_...'</pre>" +
        "<h2>faster than SQLite where it matters</h2>" +
        "<p>100k docs, both engines indexed on the same fields, same box (bench ships in the repo — <code>make bench</code>):</p>" +
        "<table><tr><th>workload</th><th>grange</th><th>SQLite</th></tr>" +
        "<tr><td>bulk insert, 2 indexes maintained</td><td><strong>278k docs/s</strong></td><td>25k rows/s</td></tr>" +
        "<tr><td>indexed count &times; 1000</td><td><strong>&lt;1 ms</strong></td><td>1.5 s</td></tr>" +
        "<tr><td>group-by count/sum/avg &times; 1000</td><td><strong>&lt;1 ms</strong> (write-time registers)</td><td>49 s</td></tr>" +
        "<tr><td>range count &times; 1000</td><td><strong>&lt;1 ms</strong></td><td>257 ms (indexed)</td></tr></table>" +
        "<div class=\"grid\">" +
        "<div class=\"card\"><h3>Crash-safe by construction</h3><p>Every commit is one immutable, checksummed WAL chunk. <code>kill -9</code> leaves exactly the committed prefix — the repo ships the harness that proves it.</p></div>" +
        "<div class=\"card\"><h3>Race-free, provably</h3><p>The server is a single actor with zero goroutines; machin's inferred data-race analysis verifies the whole engine on every build. No Send/Sync, no annotations.</p></div>" +
        "<div class=\"card\"><h3>Pay-as-you-go</h3><p>Storage: <strong>&euro;0.15/GB/month</strong>, first 50 MB free. Queries free. Accrued continuously, charged via peage — no subscription, no card on file.</p></div>" +
        "<div class=\"card\"><h3>No lock-in</h3><p>The engine is MIT OSS. Export with one curl; self-host the same binary when you outgrow the hosted rail.</p></div></div>" +
        "<h2>the interface is the docs</h2>" +
        "<pre>curl -s https://grange.intrane.fr/llms.txt   # the full contract, written for agents</pre>" +
        "<footer>grange is a single static binary written in <a href=\"https://github.com/javimosch/machin\">machin (MFL)</a>. An <a href=\"https://intrane.fr\">intrane.fr</a> experiment. Storage billed via <a href=\"https://peage.intrane.fr\">peage</a>. · <a href=\"https://github.com/javimosch/grange\">source</a> · <a href=\"https://status.dev.intrane.fr/g/grange\">status</a> · Contact: javi@intrane.fr</footer>" +
        "</main></body></html>"
}
