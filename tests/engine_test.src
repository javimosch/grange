// grange engine tests — run: machin test src/engine.src tests/engine_test.src

func tdir() (d) {
    d = "/tmp/grange-test-" + str(now_ms())
}

func main() {
    db := tdir()

    // put/get/commit
    ok, errmsg := gr_open(db, "t")
    assert(ok == 1, "open fresh db")
    gr_put("a", "{\"x\":1}")
    gr_put("b", "{\"x\":2}")
    assert(gr_commit() == 1, "commit chunk")
    doc, found := gr_get("a")
    assert_eq_int(found, 1, "get a found")
    assert_eq_str(doc, "{\"x\":1}", "get a doc")
    assert_eq_int(gr_count(), 2, "count 2")

    // durability: reopen replays the chunk
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 2, "reopen count 2")
    assert_eq_int(g_replayed_chunks, 1, "one chunk replayed")

    // overwrite latest-wins + delete
    gr_put("a", "{\"x\":9}")
    gr_del("b")
    gr_commit()
    ok, errmsg = gr_open(db, "t")
    doc, found = gr_get("a")
    assert_eq_str(doc, "{\"x\":9}", "overwrite wins after replay")
    doc, found = gr_get("b")
    assert_eq_int(found, 0, "tombstone applied after replay")
    assert_eq_int(gr_count(), 1, "count 1 after del")

    // compact folds chunks into a segment, state survives
    assert(gr_compact() == 1, "compact")
    assert_eq_int(g_gen, 1, "gen bumped")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 1, "count 1 after compact+reopen")
    assert_eq_int(g_replayed_chunks, 0, "no chunks after compact")
    doc, found = gr_get("a")
    assert_eq_str(doc, "{\"x\":9}", "doc survives compaction")

    // corrupt (torn) chunk is skipped, committed prefix survives
    gr_put("c", "{\"x\":3}")
    gr_commit()
    write_file(db + "/t/wal-" + gr_pad6(g_gen) + "-" + gr_pad6(g_next_chunk) + ".grg", "p|zz\n{\"x\":99}\n#|1|badbadbadbad\n")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(g_skipped_chunks, 1, "torn chunk skipped")
    assert_eq_int(gr_count(), 2, "committed prefix intact")
    doc, found = gr_get("zz")
    assert_eq_int(found, 0, "torn write not applied")
    // writes continue past the skipped chunk number
    gr_put("d", "{\"x\":4}")
    assert(gr_commit() == 1, "commit after torn chunk")
    ok, errmsg = gr_open(db, "t")
    assert_eq_int(gr_count(), 3, "write-after-corruption durable")

    // fresh collection in same db is isolated
    ok, errmsg = gr_open(db, "other")
    assert_eq_int(gr_count(), 0, "collections isolated")

    // ---- M1: indexes + registers ----
    ok, errmsg = gr_open(db, "ix")
    gr_put("a", "{\"s\":\"x\",\"v\":5}")
    gr_put("b", "{\"s\":\"x\",\"v\":7}")
    gr_put("c", "{\"s\":\"y\",\"v\":1}")
    gr_commit()
    gr_index_add("s", "v", "")
    assert_eq_int(g_bcount["s\t\"x\""], 2, "bucket count x=2")
    assert_eq_int(len(g_buckets["s\t\"x\""]), 2, "bucket ids x=2")
    assert_eq_str(ix_fstr(g_breg["s\t\"x\"\tv"]), "12", "register sum x=12")
    // update moves buckets and registers
    gr_put("a", "{\"s\":\"y\",\"v\":10}")
    assert_eq_int(g_bcount["s\t\"x\""], 1, "update: x count drops")
    assert_eq_int(g_bcount["s\t\"y\""], 2, "update: y count grows")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "11", "update: y sum 11")
    // delete maintains registers
    gr_del("c")
    gr_commit()
    assert_eq_int(g_bcount["s\t\"y\""], 1, "del: y count drops")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "10", "del: y sum 10")
    // declarations persist; rebuild after reopen matches
    ok, errmsg = gr_open(db, "ix")
    assert_eq_int(len(g_ifields), 1, "index decl persisted")
    assert_eq_int(g_bcount["s\t\"x\""], 1, "rebuilt count x")
    assert_eq_str(ix_fstr(g_breg["s\t\"y\"\tv"]), "10", "rebuilt register y")
    // numeric tokens index too
    gr_put("n1", "{\"k\":42,\"v\":1}")
    gr_commit()
    gr_index_add("k", "", "")
    assert_eq_int(g_bcount["k\t42"], 1, "numeric token bucket")
    assert_eq_str(ix_bucket("k", "42"), "k\t42", "ix_bucket resolves raw token")

    // ---- M2: where-ops (range filters) + query layer ----
    ok, errmsg = gr_open(db, "rq")
    gr_put("r1", "{\"s\":\"a\",\"v\":5}")
    gr_put("r2", "{\"s\":\"a\",\"v\":50}")
    gr_put("r3", "{\"s\":\"b\",\"v\":500}")
    gr_commit()
    f2, o2, v2 := wh_pairs("v>=50")
    assert_eq_int(len(f2), 1, "wh_pairs one clause")
    assert_eq_str(o2[0], ">=", "wh_pairs op >=")
    assert_eq_int(wh_match("{\"v\":50}", f2, o2, v2), 1, "v>=50 matches 50")
    assert_eq_int(wh_match("{\"v\":49}", f2, o2, v2), 0, "v>=50 rejects 49")
    f3, o3, v3 := wh_pairs("s=a,v<50")
    assert_eq_int(len(f3), 2, "wh_pairs two clauses")
    assert_eq_int(wh_match("{\"s\":\"a\",\"v\":5}", f3, o3, v3), 1, "combined eq+range matches")
    assert_eq_int(wh_match("{\"s\":\"a\",\"v\":50}", f3, o3, v3), 0, "combined rejects on range")
    cjson := q_count("v>5")
    cval, cerr := json_get(cjson, ".count")
    assert_eq_str(cval, "2", "q_count v>5 = 2")
    fjson := q_find("s=a,v>=50", 0)
    fval, ferr := json_get(fjson, ".count")
    assert_eq_str(fval, "1", "q_find combined = 1")
    ajson := q_agg("s", "v")
    asum, aerr := json_get(ajson, ".groups[1].sum_v")
    acnt, aerr2 := json_get(ajson, ".groups[1].count")
    assert(len(aerr) == 0, "q_agg has groups")

    // ---- M3: sorted range indexes + agg min/max ----
    ok, errmsg = gr_open(db, "rng")
    i := 0
    while i < 100 {
        gr_put("m" + str(i), "{\"g\":\"" + str(i % 2) + "\",\"v\":" + str(i) + "}")
        i = i + 1
    }
    gr_commit()
    gr_index_add("v", "", "range")
    rjson := q_count("v>=90")
    rv, rerr := json_get(rjson, ".count")
    assert_eq_str(rv, "10", "range count v>=90 = 10")
    rm, rerr2 := json_get(rjson, ".mode")
    assert_eq_str(rm, "\"range\"", "range mode used")
    rjson = q_count("v<10")
    rv, rerr = json_get(rjson, ".count")
    assert_eq_str(rv, "10", "range count v<10 = 10")
    // sorted order + find segment walk
    rb_ensure("v")
    assert_eq_int(len(g_rvals["v"]), 100, "projection covers all docs")
    assert(g_rvals["v"][0] <= g_rvals["v"][50], "projection sorted")
    fjson2 := q_find("v>97", 0)
    fv2, ferr2 := json_get(fjson2, ".count")
    assert_eq_str(fv2, "2", "range find v>97 = 2")
    // writes invalidate, next query rebuilds correctly
    gr_put("extra", "{\"g\":\"0\",\"v\":1000}")
    gr_commit()
    assert_eq_int(g_rdirty["v"], 1, "write marks range dirty")
    rjson = q_count("v>=1000")
    rv, rerr = json_get(rjson, ".count")
    assert_eq_str(rv, "1", "rebuild after write sees new doc")
    // agg min/max via scan
    mjson := q_agg_full("g", "", "v")
    mn, merr := json_get(mjson, ".groups[0].min_v")
    mx, merr2 := json_get(mjson, ".groups[0].max_v")
    assert(len(merr) == 0 && len(merr2) == 0, "agg min/max present")
    // range decl persists across reopen
    ok, errmsg = gr_open(db, "rng")
    assert_eq_str(g_ikind["v"], "range", "range kind persisted")
    rjson = q_count("v<=4")
    rv, rerr = json_get(rjson, ".count")
    assert_eq_str(rv, "5", "range works after reopen")

    // ---- M4: multi-collection registry (gr_use) ----
    ok, errmsg = gr_use(db, "c1")
    gr_put("a", "{\"v\":1}")
    gr_commit()
    gr_index_add("v", "", "")
    ok, errmsg = gr_use(db, "c2")
    assert_eq_int(gr_count(), 0, "use: fresh collection empty")
    gr_put("b", "{\"v\":2}")
    gr_put("c", "{\"v\":3}")
    gr_commit()
    ok, errmsg = gr_use(db, "c1")
    assert_eq_int(gr_count(), 1, "use: back to c1, state parked+restored")
    assert_eq_int(len(g_ifields), 1, "use: c1 index survives switch")
    assert_eq_int(g_bcount["v\t1"], 1, "use: c1 buckets survive switch")
    ok, errmsg = gr_use(db, "c2")
    assert_eq_int(gr_count(), 2, "use: c2 restored")
    assert_eq_int(len(g_ifields), 0, "use: c2 has no indexes")
    // uncommitted staged writes are committed on switch
    gr_put("d", "{\"v\":4}")
    ok, errmsg = gr_use(db, "c1")
    ok, errmsg = gr_open(db, "c2")
    assert_eq_int(gr_count(), 3, "use: pending write committed before park")

    // ---- M8: TTL documents ----
    ok, errmsg = gr_open(db, "ttl")
    exp := now_ms() + 600
    gr_put("short", "{\"_expires\":" + str(exp) + ",\"v\":1}")
    gr_put("forever", "{\"v\":2}")
    gr_commit()
    assert_eq_int(len(keys(g_ttl)), 1, "ttl tracked for one doc")
    doc, found = gr_get("short")
    assert_eq_int(found, 1, "ttl doc readable before expiry")
    // survives replay
    ok, errmsg = gr_open(db, "ttl")
    assert_eq_int(len(keys(g_ttl)), 1, "ttl map rebuilt on open")
    gr_put("short2", "{\"_expires\":" + str(exp) + ",\"v\":3}")
    gr_commit()
    sleep(700)
    doc, found = gr_get("short")
    assert_eq_int(found, 0, "expired doc gone on get (lazy)")
    assert_eq_int(gr_sweep_expired(), 1, "sweep removes the other expired doc")
    assert_eq_int(gr_count(), 1, "only forever doc remains")
    doc, found = gr_get("forever")
    assert_eq_int(found, 1, "non-ttl doc untouched")
    // expiry is durable (tombstone committed): reopen shows 1 doc
    ok, errmsg = gr_open(db, "ttl")
    assert_eq_int(gr_count(), 1, "expiry durable across reopen")

    // ---- M12: epoch seq: a fresh/stale follower must resync after reopen ----
    ok, errmsg = gr_open(db, "epoch")
    gr_put("e1", "{\"v\":1}")
    gr_commit()
    assert(g_seq > 1000000, "seq is epoch-based (not small int)")
    wp := watch_payload(0)
    wr, wrerr := json_get(wp, ".resync")
    assert_eq_str(wr, "1", "since=0 forces resync after open")
    wp = watch_payload(g_seq)
    wr, wrerr = json_get(wp, ".resync")
    assert_eq_str(wr, "0", "current seq is a valid delta position")

    // ---- M5: metering math ----
    // 1 GB above free tier for 30 days at 15c/GB/month = 15 cents
    free := 52428800
    c30 := tn_accrue_cents(1000000000 + free, 30 * 86400000, 15, free)
    assert(c30 > 14.99 && c30 < 15.01, "1GB for 30d = 15c")
    // half a GB for one day = 0.25c
    cday := tn_accrue_cents(500000000 + free, 86400000, 15, free)
    assert(cday > 0.2499 && cday < 0.2501, "0.5GB for 1d = 0.25c")
    // free tier costs nothing
    assert_eq_str(ix_fstr(tn_accrue_cents(free, 86400000, 15, free)), "0", "free tier = 0")
    assert_eq_str(ix_fstr(tn_accrue_cents(1000, 0, 15, free)), "0", "zero elapsed = 0")

    // ---- M18: cold storage ----
    ok, errmsg = gr_open(db, "cold")
    i = 0
    while i < 500 {
        gr_put("c" + str(i), "{\"i\":" + str(i) + ",\"grp\":\"" + str(i % 4) + "\"}")
        i = i + 1
    }
    gr_commit()
    cok, cerr := gr_cold_enable()
    assert_eq_int(cok, 1, "cold enable")
    assert_eq_int(g_cold, 1, "cold flag set")
    assert_eq_int(len(keys(g_mem)), 0, "memtable empty after initial flush")
    assert_eq_int(gr_count(), 500, "cold count matches")
    doc, found = gr_get("c123")
    assert_eq_int(found, 1, "cold get finds run doc")
    v9, v9e := json_get(doc, ".i")
    assert_eq_str(v9, "123", "cold get right doc")
    doc, found = gr_get("nope")
    assert_eq_int(found, 0, "cold get absent id")
    gr_put("c123", "{\"i\":9999,\"grp\":\"0\"}")
    gr_del("c7")
    gr_commit()
    doc, found = gr_get("c123")
    v9, v9e = json_get(doc, ".i")
    assert_eq_str(v9, "9999", "memtable overwrite shadows run")
    doc, found = gr_get("c7")
    assert_eq_int(found, 0, "memtable tombstone shadows run")
    assert_eq_int(gr_count(), 499, "cold count sees overwrite+delete")
    fok := cold_flush()
    assert_eq_int(fok, 1, "manual flush")
    assert_eq_int(len(g_run_rid), 2, "two runs")
    doc, found = gr_get("c123")
    v9, v9e = json_get(doc, ".i")
    assert_eq_str(v9, "9999", "newer run shadows older")
    doc, found = gr_get("c7")
    assert_eq_int(found, 0, "tombstone across runs")
    ok, errmsg = gr_open(db, "cold")
    assert_eq_int(g_cold, 1, "cold flag survives reopen")
    assert_eq_int(len(g_run_rid), 2, "runs loaded on reopen")
    assert_eq_int(gr_count(), 499, "count after reopen")
    fjson = q_find("grp=2", 0)
    fval, ferr = json_get(fjson, ".count")
    assert_eq_str(fval, "125", "cold find grp=2 = 125")
    cjson = q_count("i>=400")
    cval, cerr = json_get(cjson, ".count")
    assert_eq_str(cval, "101", "cold range count (scan) = 101 incl. i=9999 overwrite")
    ajson = q_agg("grp", "i")
    ac0, ace0 := json_get(ajson, ".groups[0].count")
    assert(len(ace0) == 0, "cold agg streams groups")
    assert_eq_int(gr_compact(), 1, "cold compact")
    assert_eq_int(len(g_run_rid), 1, "single run after compact")
    assert_eq_int(gr_count(), 499, "count preserved by compact")
    doc, found = gr_get("c123")
    v9, v9e = json_get(doc, ".i")
    assert_eq_str(v9, "9999", "winner survives compact")
    doc, found = gr_get("c7")
    assert_eq_int(found, 0, "delete stays deleted after compact")
    ok, errmsg = gr_open(db, "cold")
    assert_eq_int(gr_count(), 499, "compacted state durable")
    iok := gr_index_add("grp", "", "")
    assert_eq_int(iok, 0, "indexes rejected on cold")

    // ix_fstr precision (the %g bug): big integral sums print exactly
    assert_eq_str(ix_fstr(16649667.0), "16649667", "fstr big int exact")
    assert_eq_str(ix_fstr(499.5), "499.5", "fstr fraction")
    assert_eq_str(ix_fstr(0.0 - 2.25), "-2.25", "fstr negative")

    test_summary()
}
