// grange CLI — agent-first surface per https://cli-specs.intrane.fr/
//   stdout = the answer, JSON only. stderr = typed errors / context.
//   exit codes: 0 ok · 80-89 input · 90-99 resource · 110-119 internal.
//
// Verbs: put get del find count compact stats bench torture guide help-json

// ---- verbs ----

func need_db(fs) (db) {
    db = flag_get(fs, "db")
    if len(db) == 0 { emit_err(81, "input", "missing --db <dir>", 1, "pass --db pointing at the database directory") }
}

func do_open(fs) {
    ok, errmsg := gr_open(need_db(fs), flag_get(fs, "coll"))
    if ok == 0 { emit_err(110, "internal", "open failed: " + errmsg, 0, "check the --db directory is readable/writable") }
}

func cmd_put(fs) {
    doc := flag_get(fs, "doc")
    if valid_doc(doc) == 0 { emit_err(82, "input", "--doc must be single-line minified JSON starting with { or [", 1, "minify the JSON (no raw newlines) and retry") }
    id := flag_get(fs, "id")
    if len(id) == 0 { id = to_hex(rand_bytes(8)) }
    if valid_id(id) == 0 { emit_err(82, "input", "invalid --id (no | / newline, non-empty)", 1, "use a simple token id or omit --id for an auto id") }
    do_open(fs)
    gr_put(id, doc)
    if gr_commit() == 0 { emit_err(111, "internal", "wal chunk write failed", 0, "check disk space and permissions") }
    emit_ok("{\"id\":\"" + jesc(id) + "\"}")
}

func cmd_get(fs) {
    id := flag_get(fs, "id")
    if len(id) == 0 { emit_err(81, "input", "missing --id", 1, "pass --id of the document") }
    do_open(fs)
    doc, found := gr_get(id)
    if found == 0 { emit_err(90, "not-found", "no document with id " + id, 1, "check the id with: grange find") }
    emit_ok("{\"id\":\"" + jesc(id) + "\",\"doc\":" + doc + "}")
}

func cmd_del(fs) {
    id := flag_get(fs, "id")
    if len(id) == 0 { emit_err(81, "input", "missing --id", 1, "pass --id of the document") }
    do_open(fs)
    existed := gr_del(id)
    if existed == 0 { emit_err(90, "not-found", "no document with id " + id, 1, "nothing to delete") }
    if gr_commit() == 0 { emit_err(111, "internal", "wal chunk write failed", 0, "check disk space and permissions") }
    emit_ok("{\"id\":\"" + jesc(id) + "\",\"deleted\":true}")
}

func cmd_find(fs) {
    do_open(fs)
    emit_ok(q_find(flag_get(fs, "where"), flag_int_val(fs, "limit")))
}

func cmd_count(fs) {
    do_open(fs)
    emit_ok(q_count(flag_get(fs, "where")))
}

func cmd_index(fs) {
    f := flag_get(fs, "field")
    if len(f) == 0 { emit_err(81, "input", "missing --field", 1, "pass --field <name> to index") }
    do_open(fs)
    kind := ""
    if flag_on(fs, "range") { kind = "range" }
    if gr_index_add(f, flag_get(fs, "sums"), kind) == 0 { emit_err(111, "internal", "could not persist index declaration", 0, "check disk space and permissions") }
    emit_ok("{\"field\":\"" + jesc(f) + "\",\"sums\":\"" + jesc(flag_get(fs, "sums")) + "\",\"docs_indexed\":" + str(gr_count()) + "}")
}

func cmd_indexes(fs) {
    do_open(fs)
    items := []string{}
    i := 0
    while i < len(g_ifields) {
        items = append(items, "{\"field\":\"" + jesc(g_ifields[i]) + "\",\"sums\":\"" + jesc(g_isums[g_ifields[i]]) + "\"}")
        i = i + 1
    }
    emit_ok("{\"indexes\":[" + join(items, ",") + "]}")
}

func cmd_agg(fs) {
    f := flag_get(fs, "group-by")
    if len(f) == 0 { emit_err(81, "input", "missing --group-by", 1, "pass --group-by <field>") }
    do_open(fs)
    emit_ok(q_agg_full(f, flag_get(fs, "sum"), flag_get(fs, "minmax")))
}

func cmd_compact(fs) {
    do_open(fs)
    before := g_replayed_chunks
    if gr_compact() == 0 { emit_err(112, "internal", "compaction failed (segment write/verify)", 0, "check disk space; old files were NOT deleted") }
    emit_ok("{\"gen\":" + str(g_gen) + ",\"docs\":" + str(gr_count()) + ",\"chunks_merged\":" + str(before) + "}")
}

func cmd_stats(fs) {
    do_open(fs)
    emit_ok("{\"docs\":" + str(gr_count()) + ",\"gen\":" + str(g_gen) + ",\"chunks_replayed\":" + str(g_replayed_chunks) + ",\"chunks_skipped\":" + str(g_skipped_chunks) + ",\"next_chunk\":" + str(g_next_chunk) + ",\"indexes\":" + str(len(g_ifields)) + ",\"rss_kb\":" + str(bench_rss_kb()) + "}")
}

// torture: crash-test writer — puts docs in small commits until killed.
func cmd_torture(fs) {
    do_open(fs)
    n := flag_int_val(fs, "n")
    batch := flag_int_val(fs, "batch")
    if batch < 1 { batch = 100 }
    i := 0
    while i < n {
        gr_put("t" + str(i), "{\"i\":" + str(i) + "}")
        if (i + 1) % batch == 0 {
            if gr_commit() == 0 { emit_err(111, "internal", "wal write failed", 0, "disk") }
        }
        i = i + 1
    }
    gr_commit()
    emit_ok("{\"written\":" + str(n) + "}")
}

func cmd_guide() {
    println("{\"tool\":\"grange\",\"version\":\"0.1.0\",\"model\":\"document store: collections of minified-JSON docs keyed by id. Writes stage in memory and become durable at commit (one immutable checksummed WAL chunk per commit). Recovery replays the newest valid segment + its valid chunks; a torn last chunk is dropped (all-or-nothing per commit). compact folds everything into a fresh segment.\",\"loop\":[\"put --db d --doc '{...}' -> {id}\",\"get --db d --id X\",\"find --db d --where status=active --limit 50\",\"del --db d --id X\",\"index --db d --field status --sums score (declare once; makes find/count O(bucket) and count/agg O(1))\",\"agg --db d --group-by status --sum score -> per-group count/sum/avg\",\"compact --db d (fold WAL chunks into a segment; run when stats.chunks_replayed grows)\"],\"concepts\":{\"db\":\"a directory; --coll names a sub-collection (default: default)\",\"where\":\"comma-separated field=value equality, ANDed; matches string/number/bool top-level fields\",\"durability\":\"per-commit chunk files with sha256 trailers; no fsync builtin yet — OS-crash durability is best-effort, process-crash durability is exact\"},\"edge_cases\":[\"docs must be single-line minified JSON\",\"ids: no | / newline or slash\",\"where values containing , or = are not expressible in M0 — use get by id\"],\"exit_codes\":{\"0\":\"ok\",\"80-89\":\"input\",\"90-99\":\"not found\",\"110-119\":\"internal\"},\"hosted\":{\"url\":\"https://grange.intrane.fr\",\"signup\":\"POST /tenants with X-Peage-Wallet: pw_... -> isolated metered namespace + gt_ token\",\"pricing\":\"pay-as-you-go storage, 15 cents/GB/month above 50MB free, billed via peage (https://peage.intrane.fr/llms.txt)\"}}")
}

func cmd_help_json() {
    println("{\"tool\":\"grange\",\"version\":\"0.1.0\",\"summary\":\"machin-native embedded document database — agent-first, single binary\",\"commands\":[{\"name\":\"put\",\"flags\":[\"--db\",\"--coll\",\"--id\",\"--doc\"],\"out\":\"{id}\"},{\"name\":\"get\",\"flags\":[\"--db\",\"--coll\",\"--id\"],\"out\":\"{id,doc}\"},{\"name\":\"del\",\"flags\":[\"--db\",\"--coll\",\"--id\"],\"out\":\"{id,deleted}\"},{\"name\":\"find\",\"flags\":[\"--db\",\"--coll\",\"--where\",\"--limit\"],\"out\":\"{count,items}\"},{\"name\":\"count\",\"flags\":[\"--db\",\"--coll\",\"--where\"],\"out\":\"{count}\"},{\"name\":\"index\",\"flags\":[\"--db\",\"--coll\",\"--field\",\"--sums\"],\"out\":\"{field,sums,docs_indexed}\"},{\"name\":\"indexes\",\"flags\":[\"--db\",\"--coll\"],\"out\":\"{indexes}\"},{\"name\":\"agg\",\"flags\":[\"--db\",\"--coll\",\"--group-by\",\"--sum\"],\"out\":\"{group_by,mode,groups}\"},{\"name\":\"compact\",\"flags\":[\"--db\",\"--coll\"],\"out\":\"{gen,docs}\"},{\"name\":\"stats\",\"flags\":[\"--db\",\"--coll\"],\"out\":\"{docs,gen,chunks_replayed,chunks_skipped}\"},{\"name\":\"bench\",\"flags\":[\"--db\",\"--n\",\"--vs-sqlite\"],\"out\":\"benchmark metrics\"},{\"name\":\"guide\",\"flags\":[],\"out\":\"operator manual\"}]}")
}

func main() {
    fs := new_flags("grange")
    fs = flag_str(fs, "db", "d", "", "database directory")
    fs = flag_str(fs, "coll", "c", "default", "collection name")
    fs = flag_str(fs, "id", "i", "", "document id")
    fs = flag_str(fs, "doc", "D", "", "document body (minified JSON)")
    fs = flag_str(fs, "where", "w", "", "filter: field=value[,field=value] equality, ANDed")
    fs = flag_int(fs, "limit", "l", "100", "max results for find")
    fs = flag_int(fs, "n", "n", "100000", "bench/torture record count")
    fs = flag_int(fs, "batch", "b", "1000", "commit batch size")
    fs = flag_bool(fs, "vs-sqlite", "S", "bench: also run the same workload on the SQLite builtin")
    fs = flag_str(fs, "field", "f", "", "index: field to index")
    fs = flag_str(fs, "sums", "s", "", "index: comma-separated numeric fields to keep sum registers for")
    fs = flag_str(fs, "group-by", "g", "", "agg: field to group by")
    fs = flag_int(fs, "port", "p", "4444", "serve: HTTP port")
    fs = flag_str(fs, "token", "t", "", "serve: bearer token (default GRANGE_TOKEN or generated)")
    fs = flag_str(fs, "sum", "u", "", "agg: comma-separated numeric fields to sum/avg")
    fs = flag_str(fs, "minmax", "m", "", "agg: comma-separated numeric fields to min/max (scan path)")
    fs = flag_bool(fs, "range", "R", "index: also keep a sorted projection for > < >= <= queries")
    fs = parse_flags(fs, args())
    rest := flag_args(fs)
    if len(rest) == 0 {
        if flag_on(fs, "help") { println(flag_usage(fs))  return }
        emit_err(80, "input", "missing verb", 1, "run: grange help-json")
    }
    verb := rest[0]
    if verb == "put" { cmd_put(fs)  return }
    if verb == "get" { cmd_get(fs)  return }
    if verb == "del" { cmd_del(fs)  return }
    if verb == "find" { cmd_find(fs)  return }
    if verb == "count" { cmd_count(fs)  return }
    if verb == "compact" { cmd_compact(fs)  return }
    if verb == "index" { cmd_index(fs)  return }
    if verb == "indexes" { cmd_indexes(fs)  return }
    if verb == "agg" { cmd_agg(fs)  return }
    if verb == "stats" { cmd_stats(fs)  return }
    if verb == "serve" { cmd_serve(fs)  return }
    if verb == "bench" { cmd_bench(fs)  return }
    if verb == "torture" { cmd_torture(fs)  return }
    if verb == "guide" { cmd_guide()  return }
    if verb == "help-json" { cmd_help_json()  return }
    emit_err(80, "input", "unknown verb: " + verb, 1, "run: grange help-json")
}
